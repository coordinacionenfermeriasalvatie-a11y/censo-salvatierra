# ============================================================
# CENSO SALVATIERRA - Variables de entorno
# ============================================================
# IMPORTANTE:
# 1. Copia este archivo y renombralo a .env.local
# 2. Llena los valores con los datos de TU proyecto Supabase
# 3. NUNCA subas .env.local a Git (ya esta en .gitignore)
# ============================================================

# Obten estos valores en: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...tu-anon-key-aqui

# Configuracion del hospital
VITE_HOSPITAL_NOMBRE="Hospital General con Especialidades Juan Maria de Salvatierra"
VITE_HOSPITAL_CIUDAD="La Paz, Baja California Sur"
VITE_INSTITUCION="IMSS-Bienestar"
